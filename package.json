{
  "name": "quis",
  "version": "1.3.9",
  "description": "A simple DSL for data sorting and filtering",
  "type": "module",
  "main": "build/quis.js",
  "module": "build/quis.esm.js",
  "browser": "build/quis.min.js",
  "types": "build/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/types/index.d.ts",
      "import": "./build/quis.esm.js",
      "require": "./build/quis.js",
      "browser": "./build/quis.min.js",
      "default": "./build/quis.js"
    },
    "./types": {
      "types": "./build/types/types-only.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build",
    "src",
    "test",
    "scripts",
    "docs"
  ],
  "keywords": [
    "DSL",
    "data",
    "sorting",
    "filtering"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/videlais/quis.git"
  },
  "bugs": {
    "url": "https://github.com/videlais/quis/issues"
  },
  "homepage": "https://github.com/videlais/quis#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest --coverage",
    "test:node": "jest --testMatch='**/test/node/**/*.test.{js,ts}'",
    "test:web": "jest --testMatch='**/test/web/**/*.test.{js,ts}' --testEnvironment=jsdom",
    "test:all": "npm test",
    "build:types": "tsc --emitDeclarationOnly",
    "build:webpack": "webpack --mode=production",
    "build": "npm run build:types && npm run build:webpack",
    "build:dev": "webpack --mode=development",
    "clean": "rimraf build/quis.js build/quis.min.js build/types",
    "lint": "eslint ./src ./test --fix",
    "lint:check": "eslint ./src ./test",
    "typecheck": "tsc --noEmit",
    "docs:update": "cp build/quis.min.js docs/",
    "all": "npm run clean && npm run lint && npm run typecheck && npm run build && npm test"
  },
  "author": "Dan Cox",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "babel-jest": "^30.3.0",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "eslint": "^10.1.0",
    "eslint-plugin-jest": "^29.15.1",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.6.6",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
