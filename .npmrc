# ts-jest@29 declares an optional peer on @babel/core <8, but this project uses
# @babel/core@8 (via @babel/preset-env@8) only through babel-jest for .js files.
# ts-jest is configured without babelConfig, so it does not use @babel/core.
# Accept this unused optional peer until ts-jest supports @babel/core 8.
legacy-peer-deps=true
